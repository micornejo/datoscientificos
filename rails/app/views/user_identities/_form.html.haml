= form_for @user_identity do |f|
  - if @user_identity.errors.any?
    #error_explanation
      %h2= "#{pluralize(@user_identity.errors.count, "error")} prohibited this user_identity from being saved:"
      %ul
        - @user_identity.errors.full_messages.each do |msg|
          %li= msg

  .field
    = f.label :user_id
    = f.text_field :user_id
  .field
    = f.label :provider
    = f.text_field :provider
  .field
    = f.label :uid
    = f.text_field :uid
  .actions
    = f.submit 'Save'
